# Copia este archivo a credentials/.env y completa los valores reales.
# credentials/.env está en .gitignore y NO debe commitearse.

# === LLM providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# === Google Cloud / Workspace ===
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Bases de datos ===
DATABASE_URL=
REDIS_URL=

# === Integraciones ===
NOTION_TOKEN=
SLACK_BOT_TOKEN=
GITHUB_TOKEN=ghp_...

# === App ===
APP_ENV=development
LOG_LEVEL=info
