{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(//**)",
      "Write(//**)",
      "Edit(//**)",
      "Glob(//**)",
      "Grep(//**)",
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard HEAD~*)",
      "Read(./credentials/.env)",
      "Read(./credentials/*.key)",
      "Read(./credentials/*.pem)",
      "Read(./credentials/*service-account*.json)"
    ]
  },
  "env": {
    "CLAUDE_PROJECT_NAME": "bluecoast"
  }
}
